# ============ Supabase ============
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============ Postgres (Prisma) ============
# Same Postgres as Supabase. Use the transaction-mode pooler for runtime
# and the session-mode pooler for migrations.
DATABASE_URL=
DIRECT_URL=

# ============ Replicate (default image engine) ============
REPLICATE_API_TOKEN=

# ============ Vertex AI proxy (Nano Banana models) ============
# Self-hosted NestJS proxy fronting Google Vertex AI.
# Used for the Nano Banana Pro (Gemini) and Nano Banana 2 (Imagen) models.
VERTEX_API_URL=https://clip-generator-geraew-api-provider.ernvcw.easypanel.host
VERTEX_API_KEY=

# ============ OpenAI (GPT Image — gpt-image-2) ============
OPENAI_API_KEY=
OPENAI_VISION_MODEL=

# ============ kie.ai (image generation FALLBACK — Nano Banana) ============
# Usado automaticamente quando o engine primário falha ao gerar a imagem.
# Pegue a chave em https://kie.ai/api-key
# Opcional — base da API (default: https://api.kie.ai)
KIE_API_URL=

# ============ ComfyDeploy (video generation) ============
COMFYDEPLOY_API_KEY=
COMFYDEPLOY_DEPLOYMENT_ID=

# ============ PerfectPay (payment webhook) ============
# REQUIRED — the webhook rejects requests if this isn't set.
# Webhook de CRÉDITOS  -> /api/webhooks/perfectpay
PERFECTPAY_WEBHOOK_TOKEN=

# Webhook do CURSO -> /api/webhooks/perfectpay-course
# Rota dedicada: toda venda aprovada que chega nela libera a cota grátis diária
# por e-mail. Se a conta PerfectPay for a mesma, pode deixar este vazio (usa o
# PERFECTPAY_WEBHOOK_TOKEN acima). Preencha só se o token do curso for outro.
PERFECTPAY_COURSE_WEBHOOK_TOKEN=

# ============ Cron (sweeper for stale video generations) ============
# In production Vercel sends `x-vercel-cron: 1` automatically.
# This secret only matters for manual curl testing.
CRON_SECRET=

# ============ App ============
NEXT_PUBLIC_APP_URL=https://gozainfluencer.vercel.app
ADMIN_EMAIL=
