generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model Profile {
  userId       String   @id @map("user_id") @db.Uuid
  email        String?
  credits      Int      @default(0)
  languageCode String?  @map("language_code")
  banned       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
  @@schema("public")
}

model Generation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  prompt       String
  creditsSpent Int      @map("credits_spent")
  outputUrl    String?  @map("output_url")
  inputUrls    String[] @map("input_urls")
  kind         String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "generations_user_idx")
  @@map("generations")
  @@schema("public")
}

model ProcessedOrder {
  orderId    String   @id @map("order_id")
  userId     String?  @map("user_id") @db.Uuid
  pkgId      String?  @map("pkg_id")
  credits    Int
  amount     Decimal  @db.Decimal
  rawPayload Json     @map("raw_payload")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user AuthUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("processed_orders")
  @@schema("public")
}

/// E-mails liberados pela compra do curso (webhook PerfectPay). A cota grátis
/// diária vale para todo usuário cujo profiles.email conste aqui.
model CourseEntitlement {
  email      String   @id
  source     String?
  orderId    String?  @map("order_id")
  rawPayload Json?    @map("raw_payload")
  grantedAt  DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)

  @@map("course_entitlements")
  @@schema("public")
}

/// Estado da cota grátis diária por usuário (janela única de 24h + contadores
/// por bucket). Toda a lógica atômica vive nas RPCs de supabase/free-quota.sql.
model FreeQuota {
  userId      String    @id @map("user_id") @db.Uuid
  windowStart DateTime? @map("window_start") @db.Timestamptz(6)
  nanoPro     Int       @default(0) @map("nano_pro")
  nanoV2      Int       @default(0) @map("nano_v2")
  replicate   Int       @default(0)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("free_quota")
  @@schema("public")
}

/// Referência somente-leitura à tabela auth.users gerenciada pelo Supabase Auth.
model AuthUser {
  id    String  @id @db.Uuid
  email String? @unique

  profile         Profile?
  generations     Generation[]
  processedOrders ProcessedOrder[]
  freeQuota       FreeQuota?

  @@map("users")
  @@schema("auth")
}
